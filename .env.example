# Railway 部署环境变量示例
# 请在 Railway Dashboard 中设置这些环境变量

# 数据库路径（SQLite 文件位置）
DATABASE_PATH=/app/data/fund.db

# 服务器端口（Railway 会自动设置 PORT）
PORT=8000

# 会话密钥（生产环境务必替换为强随机值）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=YOUR_STRONG_SECRET_KEY_HERE

# AKShare 数据缓存时间（秒）
DATA_CACHE_TTL=3600
